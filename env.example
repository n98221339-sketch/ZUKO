# ══════════════════════════════════════════════
#  DISCORD BOT — FILE MẪU (an toàn để đăng GitHub)
#  Sao chép file này thành .env rồi điền token thật
# ══════════════════════════════════════════════

# Token bot — lấy tại https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=your_bot_token_here

# Client ID — lấy tại trang trên → OAuth2 → Client ID
CLIENT_ID=your_client_id_here
